<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="ThemeSentBubbleBrush" Color="#0078D4"/>
            <SolidColorBrush x:Key="ThemeSentTextBrush"   Color="White"/>
            <SolidColorBrush x:Key="ThemeSentUrlBrush"    Color="#CCE8FF"/>
            <SolidColorBrush x:Key="ThemeSentDateBrush"   Color="#AAFFFFFF"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="ThemeSentBubbleBrush" Color="#0A84FF"/>
            <SolidColorBrush x:Key="ThemeSentTextBrush"   Color="White"/>
            <SolidColorBrush x:Key="ThemeSentUrlBrush"    Color="#B3D9FF"/>
            <SolidColorBrush x:Key="ThemeSentDateBrush"   Color="#AAFFFFFF"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
