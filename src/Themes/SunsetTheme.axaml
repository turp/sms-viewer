<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="ThemeSentBubbleBrush" Color="#E64A19"/>
            <SolidColorBrush x:Key="ThemeSentTextBrush"   Color="White"/>
            <SolidColorBrush x:Key="ThemeSentUrlBrush"    Color="#FFAB91"/>
            <SolidColorBrush x:Key="ThemeSentDateBrush"   Color="#AAFFFFFF"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="ThemeSentBubbleBrush" Color="#FF6B3D"/>
            <SolidColorBrush x:Key="ThemeSentTextBrush"   Color="White"/>
            <SolidColorBrush x:Key="ThemeSentUrlBrush"    Color="#FFAB91"/>
            <SolidColorBrush x:Key="ThemeSentDateBrush"   Color="#AAFFFFFF"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
