<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="ThemeSentBubbleBrush" Color="#7B1FA2"/>
            <SolidColorBrush x:Key="ThemeSentTextBrush"   Color="White"/>
            <SolidColorBrush x:Key="ThemeSentUrlBrush"    Color="#CE93D8"/>
            <SolidColorBrush x:Key="ThemeSentDateBrush"   Color="#AAFFFFFF"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="ThemeSentBubbleBrush" Color="#AB47BC"/>
            <SolidColorBrush x:Key="ThemeSentTextBrush"   Color="White"/>
            <SolidColorBrush x:Key="ThemeSentUrlBrush"    Color="#E1BEE7"/>
            <SolidColorBrush x:Key="ThemeSentDateBrush"   Color="#AAFFFFFF"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
