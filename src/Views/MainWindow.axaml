<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmsViewer.ViewModels"
        xmlns:m="using:SmsViewer.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="SmsViewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SMS Viewer"
        MinWidth="600" MinHeight="400">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,6">
            <Button Command="{Binding OpenXmlFileCommand}" Content="Open SMS Backup…" />
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         Width="100" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Error banner -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red"
                   Margin="8,0,8,4" />

        <!-- Two-pane layout -->
        <Grid ColumnDefinitions="250,4,*">

            <!-- Left: conversation list -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Conversations}"
                     SelectedItem="{Binding SelectedConversation}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ConversationListItemViewModel}">
                        <StackPanel Margin="6,4" Spacing="2">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding LastMessagePreview}"
                                       FontSize="11"
                                       Opacity="0.7"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding LastMessageDate}"
                                       FontSize="10"
                                       Opacity="0.5" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" ResizeDirection="Columns" Width="4" />

            <!-- Right: message thread -->
            <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}" Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:IMessage}">
                            <Grid Margin="0,3">

                                <!-- Sent bubble (right) -->
                                <Border IsVisible="{Binding IsSent}"
                                        HorizontalAlignment="Right"
                                        MaxWidth="480"
                                        Background="#0078D4"
                                        CornerRadius="12,12,2,12"
                                        Padding="10,6"
                                        Margin="60,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayBody}"
                                                   Foreground="White"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ReadableDate}"
                                                   FontSize="10"
                                                   Foreground="#AAFFFFFF"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>

                                <!-- Received bubble (left) -->
                                <Border IsVisible="{Binding IsReceived}"
                                        HorizontalAlignment="Left"
                                        MaxWidth="480"
                                        Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}"
                                        CornerRadius="12,12,12,2"
                                        Padding="10,6"
                                        Margin="4,0,60,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayBody}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ReadableDate}"
                                                   FontSize="10"
                                                   Opacity="0.6"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
