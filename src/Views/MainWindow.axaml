<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmsViewer.ViewModels"
        xmlns:m="using:SmsViewer.Models"
        xmlns:converters="using:SmsViewer.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="SmsViewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SMS Viewer"
        MinWidth="600" MinHeight="400">

    <Window.Resources>
        <converters:ByteArrayToBitmapConverter x:Key="BytesToBitmap" />
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,6">
            <Button Command="{Binding OpenXmlFileCommand}" Content="Open SMS Backup…" />
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         Width="100" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Error banner -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red"
                   Margin="8,0,8,4" />

        <!-- Two-pane layout -->
        <Grid ColumnDefinitions="250,4,*">

            <!-- Left: conversation list + search controls -->
            <DockPanel Grid.Column="0">

                <!-- Search controls -->
                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="4,4,4,2">
                    <TextBox Text="{Binding SearchText}"
                             Watermark="Search contacts…"
                             Height="28" />
                    <Grid ColumnDefinitions="*,4,*">
                        <TextBox Grid.Column="0"
                                 Text="{Binding FilterFromDate}"
                                 Watermark="From yyyy-MM-dd"
                                 FontSize="11"
                                 Height="26" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding FilterToDate}"
                                 Watermark="To yyyy-MM-dd"
                                 FontSize="11"
                                 Height="26" />
                    </Grid>
                </StackPanel>

                <!-- No-results placeholder -->
                <TextBlock DockPanel.Dock="Top"
                           Text="No conversations match"
                           IsVisible="{Binding HasNoConversationResults}"
                           HorizontalAlignment="Center"
                           Opacity="0.5"
                           Margin="0,12" />

                <!-- Conversation list -->
                <ListBox ItemsSource="{Binding FilteredConversations}"
                         SelectedItem="{Binding SelectedConversation}"
                         BorderThickness="0,0,1,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ConversationListItemViewModel}">
                            <StackPanel Margin="6,4" Spacing="2">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding LastMessagePreview}"
                                           FontSize="11"
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding LastMessageDate}"
                                           FontSize="10"
                                           Opacity="0.5" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" ResizeDirection="Columns" Width="4" />

            <!-- Right: thread pane -->
            <DockPanel Grid.Column="2">

                <!-- Thread search -->
                <TextBox DockPanel.Dock="Top"
                         Text="{Binding ThreadSearchText}"
                         Watermark="Search messages…"
                         IsVisible="{Binding SelectedConversation, Converter={x:Static ObjectConverters.IsNotNull}}"
                         Height="28"
                         Margin="8,4,8,2" />

                <!-- Thread loading indicator -->
                <ProgressBar DockPanel.Dock="Top"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsThreadLoading}"
                             Height="3"
                             Margin="8,2,8,0" />

                <!-- No-results placeholder -->
                <TextBlock DockPanel.Dock="Top"
                           Text="No messages match"
                           IsVisible="{Binding HasNoMessageResults}"
                           HorizontalAlignment="Center"
                           Opacity="0.5"
                           Margin="0,12" />

                <!-- Message thread (ListBox provides built-in virtualization) -->
                <ListBox ItemsSource="{Binding FilteredMessages}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="8"
                         BorderThickness="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MessageViewModel}">
                                <Grid Margin="0,3">

                                    <!-- Sent bubble (right) -->
                                    <Border IsVisible="{Binding IsSent}"
                                            HorizontalAlignment="Right"
                                            MaxWidth="480"
                                            Background="#0078D4"
                                            CornerRadius="12,12,2,12"
                                            Padding="10,6"
                                            Margin="60,0,4,0">
                                        <StackPanel>
                                            <!-- Embedded images -->
                                            <ItemsControl ItemsSource="{Binding ImageData}"
                                                          IsVisible="{Binding HasImages}"
                                                          x:CompileBindings="False">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Image Source="{Binding Converter={StaticResource BytesToBitmap}}"
                                                               MaxWidth="360" MaxHeight="300"
                                                               Stretch="Uniform"
                                                               Margin="0,0,0,4" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Text with clickable URLs -->
                                            <ItemsControl ItemsSource="{Binding BodySegments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type m:BodySegment}">
                                                        <Panel HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Text}"
                                                                       IsVisible="{Binding !IsUrl}"
                                                                       Foreground="White"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Text}"
                                                                       IsVisible="{Binding IsUrl}"
                                                                       Foreground="#CCE8FF"
                                                                       TextDecorations="Underline"
                                                                       Cursor="Hand"
                                                                       PointerReleased="UrlText_PointerReleased" />
                                                        </Panel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding ReadableDate}"
                                                       FontSize="10"
                                                       Foreground="#AAFFFFFF"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Received bubble (left) -->
                                    <Border IsVisible="{Binding IsReceived}"
                                            HorizontalAlignment="Left"
                                            MaxWidth="480"
                                            Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}"
                                            CornerRadius="12,12,12,2"
                                            Padding="10,6"
                                            Margin="4,0,60,0">
                                        <StackPanel>
                                            <!-- Embedded images -->
                                            <ItemsControl ItemsSource="{Binding ImageData}"
                                                          IsVisible="{Binding HasImages}"
                                                          x:CompileBindings="False">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Image Source="{Binding Converter={StaticResource BytesToBitmap}}"
                                                               MaxWidth="360" MaxHeight="300"
                                                               Stretch="Uniform"
                                                               Margin="0,0,0,4" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Text with clickable URLs -->
                                            <ItemsControl ItemsSource="{Binding BodySegments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type m:BodySegment}">
                                                        <Panel HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Text}"
                                                                       IsVisible="{Binding !IsUrl}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Text}"
                                                                       IsVisible="{Binding IsUrl}"
                                                                       Foreground="#0057A8"
                                                                       TextDecorations="Underline"
                                                                       Cursor="Hand"
                                                                       PointerReleased="UrlText_PointerReleased" />
                                                        </Panel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding ReadableDate}"
                                                       FontSize="10"
                                                       Opacity="0.6"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>

                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>

        </Grid>
    </DockPanel>
</Window>
